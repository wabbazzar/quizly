    "dialogues": {
      "dialogue_001": {
        "title": "Asking for Directions on Campus",
        "description": "Textbook dialogue: asking how to get to the computer center",
        "lines": [
          {
            "a": "小白，下课了？上哪儿去？",
            "b": "Xiǎo Bái, xià kè le? Shàng nǎr qù?",
            "c": "Xiao Bai, class is over? Where are you going?",
            "wordAlignments": [
              { "chinese": "小白", "pinyin": "Xiǎo Bái", "english": "Xiao Bai" },
              { "chinese": "，", "pinyin": ",", "english": "," },
              { "chinese": "下课", "pinyin": "xià kè", "english": "class is over" },
              { "chinese": "了", "pinyin": "le", "english": "" },
              { "chinese": "？", "pinyin": "?", "english": "?" },
              { "chinese": "上", "pinyin": "Shàng", "english": "go" },
              { "chinese": "哪儿", "pinyin": "nǎr", "english": "where" },
              { "chinese": "去", "pinyin": "qù", "english": "to" },
              { "chinese": "？", "pinyin": "?", "english": "?" }
            ]
          },
          {
            "a": "您好，常老师。我想去学校的电脑中心，不知道怎么走，听说就在运动场旁边。",
            "b": "Nín hǎo, Cháng lǎoshī. Wǒ xiǎng qù xuéxiào de diànnǎo zhōngxīn, bù zhīdào zěnme zǒu, tīngshuō jiù zài yùndòngchǎng pángbiān.",
            "c": "Hello, Teacher Chang. I want to go to the school's computer center, but I don't know how to get there. I heard it's right next to the sports field.",
            "wordAlignments": [
              { "chinese": "您好", "pinyin": "Nín hǎo", "english": "Hello" },
              { "chinese": "，", "pinyin": ",", "english": "," },
              { "chinese": "常", "pinyin": "Cháng", "english": "Chang" },
              { "chinese": "老师", "pinyin": "lǎoshī", "english": "Teacher" },
              { "chinese": "。", "pinyin": ".", "english": "." },
              { "chinese": "我", "pinyin": "Wǒ", "english": "I" },
              { "chinese": "想", "pinyin": "xiǎng", "english": "want to" },
              { "chinese": "去", "pinyin": "qù", "english": "go to" },
              { "chinese": "学校", "pinyin": "xuéxiào", "english": "school's" },
              { "chinese": "的", "pinyin": "de", "english": "" },
              { "chinese": "电脑", "pinyin": "diànnǎo", "english": "computer" },
              { "chinese": "中心", "pinyin": "zhōngxīn", "english": "center" },
              { "chinese": "，", "pinyin": ",", "english": "," },
              { "chinese": "不", "pinyin": "bù", "english": "don't" },
              { "chinese": "知道", "pinyin": "zhīdào", "english": "know" },
              { "chinese": "怎么", "pinyin": "zěnme", "english": "how to" },
              { "chinese": "走", "pinyin": "zǒu", "english": "get there" },
              { "chinese": "，", "pinyin": ",", "english": "." },
              { "chinese": "听说", "pinyin": "tīngshuō", "english": "I heard" },
              { "chinese": "就", "pinyin": "jiù", "english": "right" },
              { "chinese": "在", "pinyin": "zài", "english": "" },
              { "chinese": "运动场", "pinyin": "yùndòngchǎng", "english": "sports field" },
              { "chinese": "旁边", "pinyin": "pángbiān", "english": "next to" },
              { "chinese": "。", "pinyin": ".", "english": "." }
            ]
          },
          {
            "a": "电脑中心没有运动场那么远。你知道学校图书馆在哪里吗？",
            "b": "Diànnǎo zhōngxīn méiyǒu yùndòngchǎng nàme yuǎn. Nǐ zhīdào xuéxiào túshūguǎn zài nǎli ma?",
            "c": "The computer center isn't as far as the sports field. Do you know where the school library is?",
            "wordAlignments": [
              { "chinese": "电脑", "pinyin": "Diànnǎo", "english": "computer" },
              { "chinese": "中心", "pinyin": "zhōngxīn", "english": "center" },
              { "chinese": "没有", "pinyin": "méiyǒu", "english": "not as" },
              { "chinese": "运动场", "pinyin": "yùndòngchǎng", "english": "sports field" },
              { "chinese": "那么", "pinyin": "nàme", "english": "that" },
              { "chinese": "远", "pinyin": "yuǎn", "english": "far" },
              { "chinese": "。", "pinyin": ".", "english": "." },
              { "chinese": "你", "pinyin": "Nǐ", "english": "you" },
              { "chinese": "知道", "pinyin": "zhīdào", "english": "know" },
              { "chinese": "学校", "pinyin": "xuéxiào", "english": "school" },
              { "chinese": "图书馆", "pinyin": "túshūguǎn", "english": "library" },
              { "chinese": "在", "pinyin": "zài", "english": "is" },
              { "chinese": "哪里", "pinyin": "nǎli", "english": "where" },
              { "chinese": "吗", "pinyin": "ma", "english": "" },
              { "chinese": "？", "pinyin": "?", "english": "?" }
            ]
          },
          {
            "a": "知道，离王朋的宿舍不远。",
            "b": "Zhīdào, lí Wáng Péng de sùshè bù yuǎn.",
            "c": "Yes, it's not far from Wang Peng's dormitory.",
            "wordAlignments": [
              { "chinese": "知道", "pinyin": "Zhīdào", "english": "Yes" },
              { "chinese": "，", "pinyin": ",", "english": "," },
              { "chinese": "离", "pinyin": "lí", "english": "from" },
              { "chinese": "王朋", "pinyin": "Wáng Péng", "english": "Wang Peng's" },
              { "chinese": "的", "pinyin": "de", "english": "" },
              { "chinese": "宿舍", "pinyin": "sùshè", "english": "dormitory" },
              { "chinese": "不", "pinyin": "bù", "english": "not" },
              { "chinese": "远", "pinyin": "yuǎn", "english": "far" },
              { "chinese": "。", "pinyin": ".", "english": "." }
            ]
          },
          {
            "a": "电脑中心离图书馆很近，就在图书馆和学生活动中心中间。",
            "b": "Diànnǎo zhōngxīn lí túshūguǎn hěn jìn, jiù zài túshūguǎn hé xuéshēng huódòng zhōngxīn zhōngjiān.",
            "c": "The computer center is very close to the library, right between the library and the student activity center.",
            "wordAlignments": [
              { "chinese": "电脑", "pinyin": "Diànnǎo", "english": "computer" },
              { "chinese": "中心", "pinyin": "zhōngxīn", "english": "center" },
              { "chinese": "离", "pinyin": "lí", "english": "from" },
              { "chinese": "图书馆", "pinyin": "túshūguǎn", "english": "the library" },
              { "chinese": "很", "pinyin": "hěn", "english": "very" },
              { "chinese": "近", "pinyin": "jìn", "english": "close" },
              { "chinese": "，", "pinyin": ",", "english": "," },
              { "chinese": "就", "pinyin": "jiù", "english": "right" },
              { "chinese": "在", "pinyin": "zài", "english": "" },
              { "chinese": "图书馆", "pinyin": "túshūguǎn", "english": "the library" },
              { "chinese": "和", "pinyin": "hé", "english": "and" },
              { "chinese": "学生", "pinyin": "xuéshēng", "english": "student" },
              { "chinese": "活动", "pinyin": "huódòng", "english": "activity" },
              { "chinese": "中心", "pinyin": "zhōngxīn", "english": "center" },
              { "chinese": "中间", "pinyin": "zhōngjiān", "english": "between" },
              { "chinese": "。", "pinyin": ".", "english": "." }
            ]
          }
        ]
      },
      "dialogue_002": {
        "title": "Going to the Bookstore Together",
        "description": "Textbook dialogue: finding the bookstore on campus",
        "lines": [
          {
            "a": "常老师，您去哪儿呢？",
            "b": "Cháng lǎoshī, nín qù nǎr ne?",
            "c": "Teacher Chang, where are you going?",
            "wordAlignments": [
              { "chinese": "常", "pinyin": "Cháng", "english": "Chang" },
              { "chinese": "老师", "pinyin": "lǎoshī", "english": "Teacher" },
              { "chinese": "，", "pinyin": ",", "english": "," },
              { "chinese": "您", "pinyin": "nín", "english": "you" },
              { "chinese": "去", "pinyin": "qù", "english": "going" },
              { "chinese": "哪儿", "pinyin": "nǎr", "english": "where" },
              { "chinese": "呢", "pinyin": "ne", "english": "" },
              { "chinese": "？", "pinyin": "?", "english": "?" }
            ]
          },
          {
            "a": "我想到学校书店去买书。",
            "b": "Wǒ xiǎng dào xuéxiào shūdiàn qù mǎi shū.",
            "c": "I want to go to the school bookstore to buy books.",
            "wordAlignments": [
              { "chinese": "我", "pinyin": "Wǒ", "english": "I" },
              { "chinese": "想", "pinyin": "xiǎng", "english": "want to" },
              { "chinese": "到", "pinyin": "dào", "english": "to" },
              { "chinese": "学校", "pinyin": "xuéxiào", "english": "school" },
              { "chinese": "书店", "pinyin": "shūdiàn", "english": "bookstore" },
              { "chinese": "去", "pinyin": "qù", "english": "go" },
              { "chinese": "买", "pinyin": "mǎi", "english": "buy" },
              { "chinese": "书", "pinyin": "shū", "english": "books" },
              { "chinese": "。", "pinyin": ".", "english": "." }
            ]
          },
          {
            "a": "书店在什么地方？",
            "b": "Shūdiàn zài shénme dìfang?",
            "c": "Where is the bookstore?",
            "wordAlignments": [
              { "chinese": "书店", "pinyin": "Shūdiàn", "english": "bookstore" },
              { "chinese": "在", "pinyin": "zài", "english": "is" },
              { "chinese": "什么", "pinyin": "shénme", "english": "what" },
              { "chinese": "地方", "pinyin": "dìfang", "english": "place" },
              { "chinese": "？", "pinyin": "?", "english": "?" }
            ]
          },
          {
            "a": "就在学生活动中心里边。我们一起走吧。",
            "b": "Jiù zài xuéshēng huódòng zhōngxīn lǐbian. Wǒmen yìqǐ zǒu ba.",
            "c": "It's inside the student activity center. Let's walk together.",
            "wordAlignments": [
              { "chinese": "就", "pinyin": "Jiù", "english": "" },
              { "chinese": "在", "pinyin": "zài", "english": "inside" },
              { "chinese": "学生", "pinyin": "xuéshēng", "english": "student" },
              { "chinese": "活动", "pinyin": "huódòng", "english": "activity" },
              { "chinese": "中心", "pinyin": "zhōngxīn", "english": "center" },
              { "chinese": "里边", "pinyin": "lǐbian", "english": "" },
              { "chinese": "。", "pinyin": ".", "english": "." },
              { "chinese": "我们", "pinyin": "Wǒmen", "english": "Let's" },
              { "chinese": "一起", "pinyin": "yìqǐ", "english": "together" },
              { "chinese": "走", "pinyin": "zǒu", "english": "walk" },
              { "chinese": "吧", "pinyin": "ba", "english": "" },
              { "chinese": "。", "pinyin": ".", "english": "." }
            ]
          }
        ]
      },
      "grammar_001": {
        "title": "Direction & Location Words: 边/面/头 Suffixes",
        "description": "Direction words combine with 边, 面, 头 to form location words",
        "lines": [
          {
