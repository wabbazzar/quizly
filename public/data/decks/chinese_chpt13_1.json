      "grammar_002": {
        "title": "Comparisons with 没有: A 没有 B (那么) Adj",
        "description": "Using meiyou to say A is not as [adjective] as B",
        "lines": [
          {
            "a": "我弟弟没有我高。",
            "b": "Wǒ dìdi méiyǒu wǒ gāo.",
            "c": "My younger brother is not as tall as I am.",
            "wordAlignments": [
              { "chinese": "我", "pinyin": "Wǒ", "english": "My" },
              { "chinese": "弟弟", "pinyin": "dìdi", "english": "younger brother" },
              { "chinese": "没有", "pinyin": "méiyǒu", "english": "not as" },
              { "chinese": "我", "pinyin": "wǒ", "english": "I" },
              { "chinese": "高", "pinyin": "gāo", "english": "tall" },
              { "chinese": "。", "pinyin": ".", "english": "." }
            ]
          },
