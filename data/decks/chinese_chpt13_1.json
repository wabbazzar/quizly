      "dialogue_002": {
        "title": "Going to the Bookstore Together",
        "description": "Textbook dialogue: finding the bookstore on campus",
        "lines": [
          {
            "a": "常老师，您去哪儿呢？",
            "b": "Cháng lǎoshī, nín qù nǎr ne?",
            "c": "Teacher Chang, where are you going?",
            "wordAlignments": [
              {
                "chinese": "常",
                "pinyin": "Cháng",
                "english": "Chang"
              },
              {
                "chinese": "老师",
                "pinyin": "lǎoshī",
                "english": "Teacher"
              },
              {
                "chinese": "，",
                "pinyin": ",",
                "english": ","
              },
              {
                "chinese": "您",
                "pinyin": "nín",
                "english": "you"
